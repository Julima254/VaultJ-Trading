<%- include('../partials/adminHeader.ejs'); -%>

<main class="admin-main">

<style>

body{
margin:0;
font-family:Arial;
background:#001f4d;
color:white;
}

.container{
width:90%;
max-width:900px;
margin:auto;
padding:20px;
}

h2,h3{
color:gold;
}

form{
margin-bottom:30px;
}

input{
padding:10px;
border-radius:6px;
border:1px solid gold;
background:#001f4d;
color:white;
width:100%;
margin-top:5px;
}

button{
padding:10px 16px;
border:none;
border-radius:6px;
cursor:pointer;
margin-top:10px;
}

.update-btn{
background:gold;
color:#001f4d;
}

.reset-btn{
background:red;
color:white;
margin-top:10px;
}

table{
width:100%;
border-collapse:collapse;
margin-top:20px;
}

thead{
background:#004080;
}

th,td{
padding:10px;
text-align:left;
}

tbody tr{
border-bottom:1px solid gold;
}

tbody tr:nth-child(even){
background:rgba(0,255,0,0.05);
}

</style>

<div class="container">

<h2>Admin SpinPot Management</h2>

<form action="/admin/spins/update" method="POST">

<label>Total Spin Pot (KES)</label>

<input
type="number"
name="totalAmount"
value="<%= spinPot?.totalAmount || 0 %>"
required
>

<button class="update-btn" type="submit">
Update Spin Pot
</button>

</form>


<!-- TOTAL DEDUCTED -->

<div style="margin-bottom:30px">

<label style="color:#00ff00;font-weight:bold;">
Total Deducted From Users
</label>

<input
type="text"
id="deductedAmount"
value="KES <%= totalDeducted %>"
readonly
>

<button
class="reset-btn"
onclick="resetDeducted()">
Reset Deducted Amount
</button>

</div>


<h3>All Spins</h3>

<table>

<thead>
<tr>
<th>User</th>
<th>Bet Amount</th>
<th>Multiplier</th>
<th>Reward</th>
<th>Date</th>
</tr>
</thead>

<tbody>

<% spins.forEach(spin=>{ %>

<tr>
<td><%= spin.user.username %></td>
<td>KES <%= spin.betAmount %></td>
<td>x<%= spin.multiplier %></td>
<td>KES <%= spin.reward %></td>
<td><%= spin.createdAt.toDateString() %></td>
</tr>

<% }) %>

</tbody>

</table>

</div>


<script>

async function resetDeducted(){

const confirmReset = confirm(
"Are you sure you want to reset total deducted? This will delete all spin history."
);

if(!confirmReset) return;

try{

const res = await fetch("/admin/spins/reset-deducted",{
method:"POST"
});

if(res.ok){

alert("Total deducted reset successfully");
location.reload();

}else{

alert("Failed to reset");

}

}catch(err){

console.error(err);
alert("Error resetting deducted amount");

}

}

</script>

</main>

</body>
</html>