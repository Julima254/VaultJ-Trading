<%- include('../partials/adminHeader.ejs'); -%>
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>referrals</title>
    <style>
        /* ===== RESET ===== */
* {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
    font-family: 'Montserrat', sans-serif;
}

/* ===== MAIN ===== */
main {
    padding: 16px;
    background-color: #E5E7EB; /* light gray background */
    min-height: 100vh;
}

/* ===== PAGE TITLE ===== */
main h1 {
    color: #FFD700; /* gold */
    font-size: 1.8rem;
    text-align: center;
    margin-bottom: 20px;
}

/* ===== NO REFERRALS MESSAGE ===== */
main p {
    text-align: center;
    color: #0f1f35; /* dark blue */
    font-weight: 500;
}

/* ===== TABLE ===== */
table {
    width: 100%;
    border-collapse: collapse;
    background-color: #fff; /* white table background */
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 4px 10px rgba(0,0,0,0.1);
}

thead {
    background-color: #0f1f35; /* dark blue header */
}

thead th {
    color: #FFD700; /* gold text */
    font-weight: 600;
    padding: 12px;
    text-align: left;
    font-size: 0.9rem;
}

tbody td {
    padding: 12px;
    font-size: 0.85rem;
    color: #0f1f35; /* dark blue text */
    border-bottom: 1px solid #E5E7EB; /* light gray border */
}

/* Alternate row colors */
tbody tr:nth-child(even) {
    background-color: #f9f9f9;
}

/* Highlight referral earnings in green */
tbody td:nth-child(4),
tbody td:nth-child(5) {
    color: #10B981; /* green */
    font-weight: 500;
}

/* ===== RESPONSIVE TABLE (mobile) ===== */
@media (max-width: 767px) {
    table, thead, tbody, th, td, tr {
        display: block;
    }

    thead {
        display: none; /* hide header for mobile */
    }

    tbody tr {
        margin-bottom: 12px;
        background-color: #fff;
        border-radius: 8px;
        box-shadow: 0 2px 6px rgba(0,0,0,0.05);
        padding: 12px;
    }

    tbody td {
        display: flex;
        justify-content: space-between;
        padding: 6px 12px;
        font-size: 0.85rem;
        border: none;
        border-bottom: 1px solid #E5E7EB;
    }

    tbody td::before {
        content: attr(data-label);
        font-weight: 600;
        color: #0f1f35;
    }
}

/* ===== TABLE CELL LABELS FOR MOBILE ===== */
tbody td[data-label]:before {
    width: 50%;
}

/* ===== TABLE STYLING TABLET (768px - 1023px) ===== */
@media (min-width: 768px) and (max-width: 1023px) {
    table {
        font-size: 0.85rem;
    }

    thead th {
        padding: 10px;
    }

    tbody td {
        padding: 10px;
    }
}

/* ===== DESKTOP (1024px+) ===== */
@media (min-width: 1024px) {
    main {
        padding: 32px 64px;
    }

    table {
        font-size: 0.9rem;
    }

    thead th {
        padding: 14px 16px;
    }

    tbody td {
        padding: 12px 16px;
    }
}
    </style>
</head>
<body>
    <main>
    <h1>Admin - Referrals</h1>

    <% if (referralData.length === 0) { %>
        <p>No referrals yet.</p>
    <% } else { %>
        <table>
            <thead>
                <tr>
                    <th>Username</th>
                    <th>Package</th>
                    <th>Total Referrals</th>
                    <th>Referral Earnings</th>
                    <th>Wallet Balance</th>
                    <th>Last Referral Date</th>
                </tr>
            </thead>
            <tbody>
                <% referralData.forEach(user => { %>
                    <tr>
                        <td><%= user.username %></td>
                        <td><%= user.package %></td>
                        <td><%= user.totalReferrals %></td>
                        <td>KES <%= user.referralEarnings %></td>
                        <td>KES <%= user.walletBalance %></td>
                        <td><%= new Date(user.lastReferral).toDateString() %></td>
                    </tr>
                <% }) %>
            </tbody>
        </table>
    <% } %>
</main>
</body>
</html>