<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" type="image/x-icon" href="/favicon.ico">
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@600;700&family=Open+Sans:wght@400;600&display=swap" rel="stylesheet">

    <style>
        /* ===== RESET ===== */
* {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
    font-family: 'Montserrat', sans-serif;
}

/* ===== HEADER ===== */
.header {
    width: 100%;
    background: #0f1f35; /* Dark blue */
    border-bottom: 1px solid rgba(255, 215, 0, 0.25);
    position: sticky;
    top: 0;
    z-index: 1000;
}

.nav-container {
    max-width: 1400px;
    margin: auto;
    padding: 12px 16px;
    display: flex;
    align-items: center;
    justify-content: space-between;
}

/* ===== LOGO ===== */
.logo img {
    height: 40px;
}

/* ===== USER INFO ===== */
.userinfo {
    text-align: right;
    color: #E5E7EB; /* light gray */
}

.userinfo .username {
    display: block;
    font-weight: 600;
    color: #FFD700; /* gold */
}

.userinfo p {
    font-size: 12px;
    color: #10B981; /* green */
}

/* ===== HAMBURGER MENU ===== */
.menu-toggle {
    background: none;
    border: 1px solid #FFD700;
    color: #FFD700;
    font-size: 22px;
    padding: 6px 10px;
    border-radius: 6px;
    cursor: pointer;
}

/* ===== NAV ===== */
.nav {
    position: fixed;
    top: 64px;
    right: -100%;
    width: 260px;
    height: calc(100vh - 64px);
    background: #0f1f35;
    transition: right 0.3s ease;
    box-shadow: -10px 0 30px rgba(0,0,0,0.4);
}

.nav.open {
    right: 0;
}

.nav ul {
    list-style: none;
    padding: 20px;
}

.nav ul li {
    margin-bottom: 12px;
}

.nav ul li a {
    display: block;
    padding: 12px 14px;
    border-radius: 8px;
    text-decoration: none;
    color: #E5E7EB;
    font-weight: 500;
    transition: all 0.25s ease;
}

.nav ul li a:hover {
    background: rgba(255, 215, 0, 0.12);
    color: #FFD700;
}

/* ===== LOGOUT ===== */
.logout-btn {
    background: rgba(16, 185, 129, 0.15);
    color: #10B981 !important;
    font-weight: 600;
}

/* ===== STATUS INDICATOR ===== */
.status {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    font-weight: 600;
}

/* Dot */
.status-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
}

/* Online */
.status.online {
    color: #10B981; /* green */
}

.status.online .status-dot {
    background: #10B981;
    box-shadow: 0 0 6px rgba(16, 185, 129, 0.8);
}

/* Inactive */
.status.inactive {
    color: #FBBF24; /* gold */
}

.status.inactive .status-dot {
    background: #FBBF24;
    box-shadow: 0 0 6px rgba(251, 191, 36, 0.7);
}

/* ===== ADMIN LINK ===== */
.admin-link {
    display: inline-block;
    margin-left: 20px;
    padding: 8px 14px;
    background-color: #FFD700; /* gold */
    color: #0f1f35; /* dark blue text */
    font-weight: 600;
    border-radius: 6px;
    text-decoration: none;
    transition: all 0.3s ease;
}

.admin-link:hover {
    background-color: #10B981; /* green on hover */
    color: #fff;
}



/* ================= TABLET ================= */
@media (min-width: 768px) {
    .logo img {
        height: 46px;
    }

    .userinfo {
        display: block;
    }

    .nav {
        width: 300px;
    }
}

/* ================= DESKTOP ================= */
@media (min-width: 1024px) {
    .nav-container {
        padding: 14px 30px;
    }

    .menu-toggle {
        font-size: 24px;
        padding: 8px 14px;
    }

    .nav {
        width: 340px;
    }

    .nav ul li a {
        font-size: 15px;
    }
}

    </style>
</head>
<body>
    <header class="header">
  <div class="nav-container">

    <!-- Logo -->
    <div class="logo">
      <a href="/home">
        <img src="/images/logo.png" alt="VaultJ Trading logo" />
      </a>
    </div>

    <% if (currentUser && currentUser.isAdmin) { %>
    <a href="/admin" class="admin-link">Admin</a>
<% } %>


    <!-- user account information-->
     <div class="userinfo">
  <% if(currentUser){ %>
    <span class="username"><%= currentUser.username %></span>
  <% } %>
  <p class="status <%= user.package && user.package !== 'None' ? 'active' : 'inactive' %>">
    <span class="status-dot"></span>
    <%= user.package && user.package !== 'None' ? 'Active' : 'Inactive' %>
</p>


</div>
    <!-- Hamburger menu (always visible) -->
    <button class="menu-toggle" aria-label="Toggle menu">☰</button>

    <!-- Navigation -->
    <nav class="nav">
      <ul>
        <li><a href="/home">Home</a></li>
        <li><a href="/account-packages">Account Packages</a></li>
        <li><a href="/copy-link">Copy referral Link</a></li>
        <li><a href="/spins">VaultJ spins</a></li>
        <li><a href="/coin">VaultJ Coin</a></li>
        <li><a href="/transaction">Transactions</a></li>
        <li><a href="/team">My Team</a></li>
        <li><a href="/profile">Profile</a></li>
        <li><a href="/customerCare">Customer Care</a></li>
        <li><a href="/logout" class="logout-btn">Logout</a></li>
      </ul>
    </nav>


  </div>
</header>

<!-- Menu Toggle JS -->
<script>
const menuToggle = document.querySelector('.menu-toggle');
const nav = document.querySelector('.nav');

menuToggle.addEventListener('click', () => {
    nav.classList.toggle('open');
});
</script>

</body>
</html>