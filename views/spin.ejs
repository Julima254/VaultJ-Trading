<%- include('partials/header.ejs'); -%>
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Spin & Win</title>

<style>
body{
    margin:0;
    font-family:Arial;
    background:#001f4d;
    color:white;
    display:flex;
    flex-direction:column;
    align-items:center;
}

.container{
    width:90%;
    max-width:400px;
    text-align:center;
    padding:15px;
}

.wallet{
    color:#00ff00;
    font-weight:bold;
    margin-top:5px;
}

input{
    width:100%;
    padding:12px;
    border-radius:8px;
    border:none;
    font-size:16px;
    margin-top:5px;
    margin-bottom:10px;
}

button{
    padding:12px 20px;
    font-size:18px;
    color:#001f4d;
    background:gold;
    border:none;
    border-radius:8px;
    cursor:pointer;
}

button:disabled{
    background:#ccc;
    cursor:not-allowed;
}

.wheel-wrapper{
    position:relative;
    width:320px;
    height:320px;
    margin:25px auto;
}

.wheel{
    width:100%;
    height:100%;
    border-radius:50%;
    background:conic-gradient(
        #004080 0deg 60deg,
        #008000 60deg 120deg,
        #ffd700 120deg 180deg,
        #0066cc 180deg 240deg,
        #00cc66 240deg 300deg,
        #ff9900 300deg 360deg
    );
    border:8px solid gold;
    box-shadow:0 0 20px gold inset;
    transition:transform 4s cubic-bezier(0.33,1,0.68,1);
}

.segment{
    position:absolute;
    width:50%;
    height:50%;
    top:0;
    left:50%;
    transform-origin:left bottom;
    display:flex;
    align-items:flex-start;
    padding-top:20px;
    padding-left:10px;
    font-weight:bold;
    color:gold;
    font-size:18px;
    transform:rotate(calc(var(--i) * 60deg));
}

.pointer{
    position:absolute;
    top:-30px;
    left:50%;
    transform:translateX(-50%);
    font-size:40px;
    color:red;
    z-index:10;
}

.winning{
    color:white;
    text-shadow:0 0 5px white,0 0 10px gold,0 0 20px gold,0 0 40px gold;
    transform:scale(1.2);
}

#result{
    margin-top:20px;
    font-size:18px;
    font-weight:bold;
    color:gold;
}
</style>
</head>

<body>

<div class="container">

<h1>🎡 Spin & Win</h1>

<div class="wallet">
Wallet Balance: <span id="wallet-balance">KES <%= walletBalance %></span>
</div>

<form id="spin-form">
<label>Enter Bet Amount (KES 10 - 2000)</label>
<input type="number" id="betAmount" min="10" max="2000" required>
<button id="spin-btn">SPIN</button>
</form>

<div class="wheel-wrapper">
    <div class="pointer">▼</div>
    <div class="wheel" id="wheel">
        <div class="segment" style="--i:0;">0x</div>
        <div class="segment" style="--i:1;">0.5x</div>
        <div class="segment" style="--i:2;">1x</div>
        <div class="segment" style="--i:3;">2x</div>
        <div class="segment" style="--i:4;">5x</div>
        <div class="segment" style="--i:5;">10x</div>
    </div>
</div>

<div id="result"></div>

</div>

<audio id="tickSound">
<source src="/sounds/tick.mp3" type="audio/mpeg">
</audio>

<script>
const form = document.getElementById('spin-form');
const wheel = document.getElementById('wheel');
const resultDiv = document.getElementById('result');
const walletSpan = document.getElementById('wallet-balance');
const spinBtn = document.getElementById('spin-btn');

let walletBalance = parseInt("<%= walletBalance || 0 %>");
let spinPotAmount = 0;

// Load Spin Pot
async function getSpinPot(){
    try{
        const res = await fetch('/spins/pot');
        const data = await res.json();
        spinPotAmount = data.totalAmount || 0;

        if(walletBalance < 10){
            spinBtn.disabled = true;
            resultDiv.innerHTML = "<span style='color:red'>Wallet too low to spin</span>";
        }

        if(spinPotAmount <= 0){
            spinBtn.disabled = true;
            resultDiv.innerHTML = "<span style='color:red'>Spin pot empty</span>";
        }

    }catch(err){
        console.error(err);
        spinBtn.disabled = true;
        resultDiv.innerHTML = "<span style='color:red'>Unable to load spin pot</span>";
    }
}

getSpinPot();

// Spin Logic
form.addEventListener('submit', async e=>{
    e.preventDefault();

    const betAmount = Number(document.getElementById('betAmount').value);

    if(betAmount < 10 || betAmount > 2000) return alert("Bet must be 10-2000");
    if(betAmount > walletBalance) return alert("Insufficient wallet");
    if(betAmount > spinPotAmount) return alert("Spin pot insufficient");

    spinBtn.disabled = true;
    resultDiv.textContent = "Spinning...";

    try{
        const res = await fetch('/spins/play',{
            method:'POST',
            headers:{'Content-Type':'application/json'},
            body:JSON.stringify({betAmount})
        });

        const data = await res.json();

        if(!data.success){
            resultDiv.innerHTML = `<span style="color:red">${data.message}</span>`;
            spinBtn.disabled = false;
            return;
        }

        // Calculate finalAngle based on multiplier
        const multipliers = [0,0.5,1,2,5,10];
        const multiplierIndex = multipliers.indexOf(data.multiplier);
        const anglePerSegment = 360 / multipliers.length;
        const fullSpins = 5; // spins before stopping
        const finalAngle = 360 * fullSpins + (multiplierIndex * anglePerSegment) - 90 + (anglePerSegment / 2);

        // Animate wheel
        wheel.style.transition = 'transform 4s cubic-bezier(0.33,1,0.68,1)';
        wheel.style.transform = `rotate(${finalAngle}deg)`;

        // Update balances instantly
        walletBalance = data.walletBalance;
        walletSpan.textContent = `KES ${walletBalance}`;

        // If using separate spinning balance
        if(data.spinningBalance !== undefined){
            let spinningEl = document.getElementById('spinning-balance');
            if(spinningEl) spinningEl.textContent = data.spinningBalance;
        }

        // Show result after spin ends
        setTimeout(()=>{
            resultDiv.innerHTML = `You bet <strong>KES ${betAmount}</strong> and won <strong>KES ${data.reward}</strong>!<br>
            Your wallet now has <strong>KES ${walletBalance}</strong>`;
            spinBtn.disabled = false;
        }, 4000);

    }catch(err){
        console.error(err);
        resultDiv.innerHTML = `<span style="color:red">${err.message}</span>`;
        spinBtn.disabled = false;
    }
});
</script>

</body>
</html>