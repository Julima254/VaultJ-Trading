<%- include('partials/header.ejs'); -%>
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
     <link rel="icon" type="image/x-icon" href="/favicon.ico">
    <title>VaultJ-Trading</title>
    <link rel="stylesheet" href="/styles/main.css"/>
</head>
<body>
    <main class="user-dashboard">

    <!-- =====================
         TOP SUMMARY SECTION
    ====================== -->
    <section class="dashboard-summary">

        <div class="summary-item">
            <p>My Package</p>
            <h4><%= user.package %></h4>
        </div>

        <div class="summary-item">
            <p>Wallet Balance</p>
            <h4>KES <%= user.walletBalance %></h4>
        </div>

        <div class="summary-item">
            <p>Total Referrals</p>
            <h4><%= totalReferrals %></h4>
        </div>

        <div class="summary-item">
            <p>Spinning Balance</p>
            <h4>KES <%= user.spinningBalance %></h4>
        </div>

        <div class="summary-item">
            <p>Coin Balance</p>
            <h4><%= user.coinBalance %></h4>
        </div>

        <div class="summary-item">
            <p>Deposit Balance</p>
            <h4>KES <%= user.depositBalance %></h4>
        </div>

    </section>

    <!-- =====================
         ACTION BUTTONS
    ====================== -->
    <section class="dashboard-actions">

        <a href="/deposit" class="action-btn">Deposit</a>

        <a href="/withdraw" class="action-btn">Withdraw</a>

        <a href="/upgrade-package" class="action-btn">Upgrade Package</a>

    </section>

    <!-- =====================
         RECENT TRANSACTIONS
    ====================== -->
    <section class="recent-transactions">

        <h4>Recent Transactions</h4>

        <table>
            <thead>
                <tr>
                    <th>Code</th>
                    <th>Amount</th>
                    <th>Status</th>
                    <th>Date</th>
                </tr>
            </thead>

            <tbody>
                <% if (!transactions || transactions.length === 0) { %>
                    <tr>
                        <td colspan="4" style="text-align:center;">
                            No transactions found
                        </td>
                    </tr>
                <% } else { %>
                    <% transactions.forEach(tx => { %>
                        <tr>
                            <td><%= tx.code %></td>
                            <td>KES <%= tx.amount %></td>
                            <td><%= tx.status %></td>
                            <td><%= tx.createdAt.toDateString() %></td>
                        </tr>
                    <% }) %>
                <% } %>
            </tbody>
        </table>

    </section>

</main>
</body>
</html>